                    "email",
                    "valid",
                    "error"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "email": {
                        "label": "Email",
                        "format": "text"
                    },
                    "valid": {
                        "label": "Valid",
                        "format": "boolean"
                    },
                    "error": {
                        "label": "Error",
                        "format": "text"
                    }
                }
