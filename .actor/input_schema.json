{
    "title": "Email Validation Service Input",
    "description": "Provide one or more emails to validate through the external validation API.",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "email": {
            "title": "Email",
            "type": "string",
            "editor": "textfield",
            "description": "Single email address to validate.",
            "prefill": "hello@example.com"
        },
        "emails": {
            "title": "Emails",
            "type": "array",
            "editor": "stringList",
            "description": "List of email addresses to validate.",
            "items": {
                "type": "string"
            }
        }
    }
}
